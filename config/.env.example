# ============================================================
# SAP_to_Data_Platform — configuración
# Copiar a config/.env y rellenar. NO commitear config/.env.
# ============================================================

# --- Modo de conexión a SAP ---
# Valores válidos: "service_layer" | "hana" | "mssql" | "csv_drop"
#
# Modo REAL hoy: csv_drop (lee .xlsx exportados desde SAP B1 Query Manager)
# Los otros modos están listos por si en el futuro TI habilita algún endpoint.
SAP_MODE=csv_drop

# --- Service Layer (OPCIÓN A, recomendada) -------------------
SAP_SL_URL=https://sapb1tmx.com.mx:50000/b1s/v1
SAP_SL_COMPANY_DB=SBO_JKKPACK
SAP_SL_USER=
SAP_SL_PASSWORD=
SAP_SL_VERIFY_SSL=false

# --- HANA directo (OPCIÓN B) --------------------------------
SAP_HANA_HOST=
SAP_HANA_PORT=30015
SAP_HANA_SCHEMA=SBO_JKKPACK
SAP_HANA_USER=
SAP_HANA_PASSWORD=

# --- MSSQL directo (OPCIÓN B alterna) -----------------------
SAP_MSSQL_HOST=
SAP_MSSQL_PORT=1433
SAP_MSSQL_DB=SBO_JKKPACK
SAP_MSSQL_USER=
SAP_MSSQL_PASSWORD=
# ODBC Driver name. Normal: "ODBC Driver 18 for SQL Server"
SAP_MSSQL_DRIVER=ODBC Driver 18 for SQL Server

# --- CSV / XLSX drop (MODO ACTIVO) --------------------------
# Carpeta donde el operador (FI002 en RemoteApp) deja los archivos
# exportados desde Query Manager con nombre <TABLA>_<YYYYMMDD>.xlsx
# Recomendado: sincronizar con Google Drive / OneDrive / Dropbox.
SAP_CSV_DROP_DIR=/Users/josekuri/claude/SAP_to_Data_Platform/data/drop

# --- Acceso humano documentado (NO usar para extraer) -------
# Este portal es TSplus RemoteApp, solo sirve para operación manual.
SAP_WEB_PORTAL_URL=https://sapb1tmx.com.mx/
SAP_WEB_PORTAL_USER=JKKU006
SAP_WEB_PORTAL_PASSWORD=
SAP_APP_USER=FI002
SAP_APP_PASSWORD=

# --- PostgreSQL (Fase 4) ------------------------------------
PG_HOST=localhost
PG_PORT=5432
PG_DB=sap_historico
PG_USER=sap_reader
PG_PASSWORD=

# --- WhatsApp vía SOMAS -------------------------------------
SOMAS_WHATSAPP_URL=https://somas.jkkpack.app/api/whatsapp/send
SOMAS_INTER_APP_SECRET=jkkpack-inter-app-2026
REPORT_WHATSAPP_NUMBER=5215526539904

# --- Proyecto ----------------------------------------------
PROJECT_ROOT=/Users/josekuri/claude/SAP_to_Data_Platform
EXTRACT_SINCE=2020-01-01
EXTRACT_PAGE_SIZE=1000
